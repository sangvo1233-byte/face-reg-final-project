# ── Unrelated local folders ─────────────────────────────────
Computer Vision Share/

# ── Pre-trained model files (too large for GitHub) ──────────
models/

# ── Python ──────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
*.egg

# ── Virtual environments ─────────────────────────────────────
.venv
venv/
env/

# ── Environment / secrets ────────────────────────────────────
