.env
.env.*
!.env.example

# ── Certificates & private keys ─────────────────────────────
*.pem
*.key
*.crt
*.p12
*.pfx
id_rsa
id_rsa.*
id_ed25519
id_ed25519.*

# ── Database (local runtime data — do not commit) ────────────
database/*.db
database/*.db-shm
database/*.db-wal
database/*.db-journal
database/*.sqlite
database/*.sqlite3
database/backups/

# ── Logs & runtime artifacts ─────────────────────────────────
logs/evidence/
logs/face_crops/
logs/evidence_archived_*/
logs/*.log
*.log

# ── Tunnel ───────────────────────────────────────────────────
tunnel_log*.txt

# ── Web demo video (large — share via Drive) ─────────────────
web/demo.mp4

# ── OS ───────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── IDE ──────────────────────────────────────────────────────
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# ── Jupyter ──────────────────────────────────────────────────
.ipynb_checkpoints/

# ── Cloudflared ──────────────────────────────────────────────
*.bat.log

# ── Pytest & coverage ────────────────────────────────────────
pytest-cache-files-*/
.pytest_cache/
.coverage
coverage.xml
htmlcov/

# ── Test result artifacts ────────────────────────────────────
tests/test_result.txt

# ── Temp directories ─────────────────────────────────────────
tmp/
temp/
