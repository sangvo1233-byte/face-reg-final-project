# =============================================================
# Face Attendance System — Environment Variable Reference
# =============================================================
# Copy this file to `.env` and fill in your local values.
# `.env` is listed in .gitignore and must NOT be committed.
# This file (.env.example) is safe to commit — it contains no
# real credentials, only documented defaults.
# =============================================================

# ── App identity ────────────────────────────────────────────
APP_NAME=Face Attendance System
APP_VERSION=4.4.0

# Set to "production" to disable debug mode and hot reload
APP_ENV=development

# Override individual flags (default follows APP_ENV)
# DEBUG=false
# UVICORN_RELOAD=false
# API_DOCS_ENABLED=false

# ── Server ───────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000

# ── Camera ───────────────────────────────────────────────────
# 0 = default webcam; use an RTSP URL for IP cameras
# CAMERA_SOURCE=0

# Treat camera startup failure as a fatal error
# CAMERA_REQUIRED=false

# ── Model loading ────────────────────────────────────────────
# AUTO_PRELOAD_MODELS=true
# AUTO_LOAD_EMBEDDING_CACHE=true
# AUTO_START_CAMERA=true

# ── CORS / trusted hosts (comma-separated) ───────────────────
# CORS_ALLOWED_ORIGINS=https://yourdomain.com,https://other.com
# TRUSTED_HOSTS=yourdomain.com,other.com
